---
import { parse } from 'yaml';
import patentsYaml from '../data/patents.yaml?raw';

const patentsData = parse(patentsYaml);

const sortPatents = (patents) => {
  return [...patents].sort((a, b) => {
    // Issued first (has patent_no)
    if (a.patent_no && !b.patent_no) return -1;
    if (!a.patent_no && b.patent_no) return 1;
    
    // Within same status, sort by date (registration_date for issued, application_date for pending)
    const dateA = a.patent_no ? a.registration_date : a.application_date;
    const dateB = b.patent_no ? b.registration_date : b.application_date;
    return new Date(dateB) - new Date(dateA);
  });
};

const sortedPatents = sortPatents(patentsData);
---

<dt><i>Patents</i> 💡</dt>

<dd>
  {sortedPatents.map((patent, index) => (
    <div style="margin-bottom: 0.5em;">
      <strong>[P{index + 1}] {patent.title}</strong>
      <span style="font-size: 0.8em; color: #666;">
        {' '}{<b>{patent.country}</b>}
        {patent.patent_no && <> {patent.patent_no} (Issued: {patent.registration_date})</>}
        {!patent.patent_no && <> {patent.application_no} (Pending: {patent.application_date})</>}
      </span>
    </div>
  ))}
</dd>
