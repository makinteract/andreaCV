<script>
  fetch('https://personal-scholar.onrender.com/author/wVDtZB0AAAAJ')
    .then(response => response.json())
    .then(data => {
      document.querySelector('.citations strong').textContent = data.citations;
      document.querySelector('.h-index strong').textContent = data.h_index;
    })
    .catch(() => {
      document.querySelector('.citations strong').textContent = '1502';
      document.querySelector('.h-index strong').textContent = '21';
    });

  fetch('/assets/data/publications.bib')
    .then(res => res.text())
    .then(data => {
      const inproc = (data.match(/@inproceedings/g) || []).length;
      const article = (data.match(/@article/g) || []).length;
      document.querySelector('.inproc strong').textContent = inproc;
      document.querySelector('.article strong').textContent = article;
    });
</script>

