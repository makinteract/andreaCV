---
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

let citations = '...';
let h_index = '...';
const andreaScholarId = 'wVDtZB0AAAAJ&hl=en';
const serverUrl = 'https://personal-scholar.onrender.com';

try {
  const res = await fetch(`${serverUrl}/citations/${andreaScholarId}`);
  const data = await res.json();
  citations = data.citations.all;
} catch (e) {
  // leave defaults
}
try {
  const res = await fetch(`${serverUrl}/h-index/${andreaScholarId}`);
  const data = await res.json();
  h_index = data.h_index.all;
} catch (e) {
  // leave defaults
}



const bibData = readFileSync(resolve('src/data/andrea-pub.bib'), 'utf-8');
const inproc = (bibData.match(/@inproceedings/g) || []).length;
const article = (bibData.match(/@article/g) || []).length;
---

<dt><i>Highlights</i> ⭐️</dt>
<dd id="highlights-content">
  <ul>
    <li>
      Research in the field of <em>Human-Computer Interaction (HCI)</em>: 
      <div class="indent"><strong>AR-VR</strong> / <strong>Haptics</strong> / <strong>Physical computing</strong></div>
    </li>
    <li>
      Citations: <span class="citations"><strong>{citations}</strong></span> H-index: <span class="h-index"><strong>{h_index}</strong></span>
    </li>
    <li>
      <span class="inproc"><strong>{inproc}</strong></span> international conference and <span class="article"><strong>{article}</strong></span> journal papers
    </li>
    <li>
      <strong>Best Paper Awards</strong> UIST 2020, TEI 2021, MobileHCI 2013
    </li>
    <li>
      <strong>5 CHI Honorable Mention Awards</strong> and <strong>4 at other ACM conferences</strong>
    </li>
    <li>
      <strong>4 KAIST awards</strong> for International Cooperation and Research Excellence
    </li>
    <li>
      UIST 2025 <strong>Paper Co-Chair</strong> 
    </li>
  </ul>
</dd>

<style>
  dt {
    color: #FF0070;
  }
  .indent {
    margin-left: 2em;
  }
</style>
