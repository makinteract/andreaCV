<dt><i>Fundings</i> 💵</dt>

<dd id="projects-container">
  <p>Loading projects...</p>
</dd>

<script>
  interface Project {
    Title: string;
    PrjNumber: string;
    Role: string;
    FundingAgency: string;
    Start: string;
    End: string;
    Amount: string;
  }

  fetch('/assets/data/projects.csv')
    .then(response => response.text())
    .then(data => {
      const projects: Project[] = [];
      
      (window as any).Papa.parse(data, {
        header: true,
        delimiter: ',',
        step: function (row: { data: Project }) {
          projects.push(row.data);
        },
        complete: function () {
          projects.sort((a, b) => {
            const da = new Date(a.Start).getTime();
            const db = new Date(b.Start).getTime();
            return db - da;
          });

          const container = document.getElementById('projects-container') as HTMLElement | null;
          if (!container) return;
          container.innerHTML = '';

          projects.forEach(project => {
            const h4 = document.createElement('h4');
            h4.textContent = project.Title + ' [' + project.PrjNumber + ']';
            
            const detail = document.createElement('div');
            detail.className = 'patentDetail';
            detail.textContent = 'Role: ' + project.Role + ' | Funding Agency: ' + project.FundingAgency + ' ' + project.Start + ' - ' + project.End + ' | ' + project.Amount + '₩';
            
            container.appendChild(h4);
            container.appendChild(detail);
          });
        }
      });
    });
</script>
